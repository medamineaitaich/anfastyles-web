# Local dev (default is http://localhost:3001 if unset)
VITE_API_BASE_URL=http://localhost:3001

# WordPress bridge base URL (WooPayments config)
# Default: https://wp.anfastyles.shop
VITE_WP_BASE_URL=https://wp.anfastyles.shop

# Production example:
# VITE_API_BASE_URL=https://api-layer.anfastyles.shop

# Stripe publishable key (test mode) for Store API + Stripe gateway checkout
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Meta Pixel ID (client-side only; safe to expose)
VITE_META_PIXEL_ID=

